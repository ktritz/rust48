{
  "name": "rust48-electron",
  "version": "0.1.0",
  "description": "HP-48 GX emulator Electron shell",
  "author": "ktritz",
  "main": "main.js",
  "build": {
    "appId": "com.rust48.app",
    "productName": "rust48",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "../target/electron"
    },
    "files": [
      "main.js",
      "package.json",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": ["**/*"]
      }
    ],
    "linux": { "target": ["AppImage"], "icon": "../src-tauri/icons/icon.png" },
    "mac": { "target": ["dmg"], "icon": "../src-tauri/icons/icon.png" },
    "win": { "target": ["nsis", "portable"], "icon": "../src-tauri/icons/icon.ico" }
  }
}
